# LLM Configurations
# Obtain key from NVIDIA NIM Developer portal (free tier).
NVIDIA_API_KEY=nvapi-your-key-here

# Notion Configurations
# Obtain Page ID from the URL of your parent Notion page.
# Share this parent page with your Notion integrations.
NOTION_PARENT_PAGE_ID=your-parent-page-id-here

# Notion Integration Tokens. You can use the same token for testing
# or create separate integration tokens to enforce separate permissions.
NOTION_ORCHESTRATOR_TOKEN=ntn_your_orchestrator_token_here
NOTION_MARKETING_TOKEN=ntn_your_marketing_token_here
NOTION_FINANCE_TOKEN=ntn_your_finance_token_here
NOTION_ENGINEERING_TOKEN=ntn_your_engineering_token_here

# These will be automatically filled or printed by running the setup script:
# npm run setup (in notion-setup)
NOTION_INITIATIVES_DB_ID=
NOTION_AGENTLOG_DB_ID=
NOTION_DECISIONS_DB_ID=
NOTION_ACTIONS_DB_ID=

# Webhook Security
# Shared secret to sign and verify incoming Notion webhook requests.
WEBHOOK_SHARED_SECRET=ai-enterprise-secret-2026

# External Integrations
# GitHub Personal Access Token (PAT) with repo scope
GITHUB_TOKEN=ghp_placeholder123456789
# Repository target where the engineering agent creates issues (format: owner/repo)
GITHUB_REPO=Madihawahab/AI_Enterprise_OS

# Slack Bot Token (xoxb-...) and the Channel ID where notifications are sent
SLACK_BOT_TOKEN=xoxb-placeholder
SLACK_CHANNEL_ID=C0000000000

# Port and Base URL for local server and public webhook tunneling (e.g. ngrok)
PORT=3000
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app
